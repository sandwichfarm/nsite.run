{
  "workspace": [
    "./apps/relay",
    "./apps/blossom",
    "./apps/gateway",
    "./packages/shared"
  ],
  "nodeModulesDir": "none",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    "dev": "deno run --allow-all scripts/dev.ts",
    "build": "deno task --filter '@nsite/relay' build && deno task --filter '@nsite/blossom' build && deno task --filter '@nsite/gateway' build",
    "test": "deno test --allow-all --recursive",
    "check": "deno check apps/relay/src/main.ts apps/blossom/src/main.ts apps/gateway/src/main.ts packages/shared/src/mod.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "exclude": [
      ".planning/",
      ".git/",
      ".worktrees/",
      "apps/spa/",
      ".github/",
      "docs/",
      "test-results/",
      ".nsite/",
      "node_modules/",
      "packages/deployer/",
      "packages/stealthis/"
    ]
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": [
      ".planning/",
      ".git/",
      ".worktrees/",
      "apps/spa/",
      ".github/",
      "docs/",
      "test-results/",
      ".nsite/",
      "node_modules/",
      "packages/deployer/",
      "packages/stealthis/"
    ]
  },
  "test": {
    "exclude": [
      ".planning/",
      ".git/",
      ".worktrees/",
      "apps/spa/",
      ".github/",
      "docs/",
      "test-results/",
      ".nsite/",
      "node_modules/",
      "packages/deployer/",
      "packages/stealthis/"
    ]
  }
}
